<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Atributos para FooterButtons -->
    <declare-styleable name="FooterButtons">
        <attr name="primaryText" format="string" />
        <attr name="secondaryText" format="string" />
    </declare-styleable>

    <!-- Atributos para Header -->
    <declare-styleable name="Header">
        <attr name="title" format="string" />
        <attr name="showBackButton" format="boolean" />
        <attr name="showActionButton" format="boolean" />
        <attr name="actionIcon" format="reference" />
        <attr name="backgroundColor" format="color" />
        <attr name="textColor" format="color" />
    </declare-styleable>
</resources>