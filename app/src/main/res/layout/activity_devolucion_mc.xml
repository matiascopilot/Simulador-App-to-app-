<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <!-- Header Component -->
    <cl.ione.simuladorapptoapp.components.Header
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- ScrollView para el contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background_main"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Authorization Code -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Código Autorización"
                app:boxBackgroundColor="?attr/colorSurface"
                app:boxStrokeColor="?attr/colorOnSurface"
                app:hintTextColor="?attr/colorOnSurface"
                app:placeholderText="Ej: ABCD1234"
                app:endIconMode="clear_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAuthorizationCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLength="20"
                    android:text="ABCD1234"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- RUT Comercio Hijo -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="RUT Comercio Hijo"
                app:boxBackgroundColor="?attr/colorSurface"
                app:boxStrokeColor="?attr/colorOnSurface"
                app:hintTextColor="?attr/colorOnSurface"
                app:placeholderText="Ej: 12.345.678-5"
                app:endIconMode="clear_text">

                <cl.ione.simuladorapptoapp.components.RutEditText
                    android:id="@+id/etRutCommerceSon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLength="12"
                    android:text="09.091.125-2"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Monto -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Monto ($)"
                app:boxBackgroundColor="?attr/colorSurface"
                app:boxStrokeColor="?attr/colorOnSurface"
                app:hintTextColor="?attr/colorOnSurface"
                app:placeholderText="Ej: $1.000"
                app:endIconMode="clear_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="12"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ¿Imprimir en POS? -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="¿Imprimir en POS?"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />

            <RadioGroup
                android:id="@+id/rgPrintOnPos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbPrintYes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="Sí"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbPrintNo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="No"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

            </RadioGroup>

        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_main"
        android:orientation="vertical"
        android:padding="8dp">

        <cl.ione.simuladorapptoapp.components.FooterButtons
            android:id="@+id/footerButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="VOLVER"
            app:secondaryText="DEVOLVER" />

    </LinearLayout>

</LinearLayout>