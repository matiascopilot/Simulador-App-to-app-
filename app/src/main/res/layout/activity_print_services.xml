<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Header -->
    <cl.ione.simuladorapptoapp.components.Header
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:title="Servicio de Impresión"
        app:showBackButton="true" />

    <!-- Footer Buttons (SOLO UNA VEZ) -->
    <LinearLayout
        android:id="@+id/footerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_main"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <cl.ione.simuladorapptoapp.components.FooterButtons
            android:id="@+id/footerButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="CANCELAR"
            app:secondaryText="IMPRIMIR" />

    </LinearLayout>

    <!-- Guía para el centro del espacio disponible -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="0dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_end="0dp" />

    <!-- CardView Circular con ícono - CENTRADO ENTRE HEADER Y FOOTER -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardIcon"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:cardBackgroundColor="@color/primary_red_light"
        app:cardCornerRadius="70dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintBottom_toTopOf="@+id/guideline_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideline_top">

        <!-- ImageView con ícono de impresión -->
        <ImageView
            android:id="@+id/btnIniciarImpresion"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="Iniciar impresión"
            android:focusable="true"
            android:scaleType="fitCenter"
            android:src="@drawable/print" />

    </androidx.cardview.widget.CardView>

    <!-- Texto de instrucción principal -->
    <TextView
        android:id="@+id/tvInstruccion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Toca el icono o presiona IMPRIMIR\npara enviar la solicitud \n (Recuerda activar G-Services)"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardIcon" />

</androidx.constraintlayout.widget.ConstraintLayout>